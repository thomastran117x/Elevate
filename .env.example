########################################
# Environment
########################################
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

########################################
# URLs & proxy
########################################
FRONTEND_URL=http://localhost:3090
# Backend base URL for local (non-docker) runs.
BACKEND_URL=http://localhost:8090/api
# Optional docker overrides (see docker-compose.yml). Kept on distinct names so the
# dockerized browser API base does not collide with BACKEND_URL above:
#   FRONTEND_BACKEND_URL      -> browser API base (default http://localhost:3090/api, proxied)
#   FRONTEND_API_PROXY_TARGET -> SSR proxy upstream (default http://backend:8090)
# FRONTEND_BACKEND_URL=
# FRONTEND_API_PROXY_TARGET=
# Angular 21 SSR Host allowlist (SSRF protection). Comma-separated hostnames, no ports.
# Must include every host the frontend is served on, or the SSR server returns 400.
NG_ALLOWED_HOSTS=localhost,127.0.0.1

########################################
# Shared infra (main server + workers)
########################################
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_URL=redis:6379
DB_CONNECTION_STRING=Server=mysql;Port=3306;Database=appdb;User=appuser;Password=apppass
BACKEND_PORT=8090
LOG_LEVEL=info

########################################
# Feature flags (main server + frontend)
########################################
FEATURE_AUTH=true
FEATURE_CLUBS=true
FEATURE_CLUBS_FOLLOW=true
FEATURE_CLUBS_POSTS=true
FEATURE_CLUBS_REVIEWS=true
FEATURE_CLUBS_VERSIONING=true
FEATURE_EVENTS=true
FEATURE_EVENTS_ANALYTICS=true
FEATURE_EVENTS_IMAGES=true
FEATURE_EVENTS_INVITATIONS=true
FEATURE_EVENTS_REGISTRATION=true
FEATURE_EVENTS_VERSIONING=true
FEATURE_PAYMENT=true
FEATURE_PROFILE=true
FEATURE_PROFILE_ADMIN=true
FEATURE_SEARCH=true
FEATURE_SEARCH_REINDEX=true

########################################
# Auth / JWT / MFA
########################################
JWT_SECRET_ACCESS=change_me_access_secret_12345678901234567890
JWT_SECRET_VERIFICATION=change_me_verification_secret_12345678901234567890
# SMS MFA (shared: main server + sms-worker)
AUTH_SMS_MFA_ENROLLMENT_ENABLED=true
AUTH_SMS_MFA_ENFORCEMENT_ENABLED=false
AUTH_SMS_MFA_STEP_UP_SMS_ENABLED=true
# TOTP MFA. AUTH_TOTP_ENCRYPTION_KEY must be base64 for exactly 32 bytes in production.
AUTH_TOTP_ENCRYPTION_KEY=
AUTH_TOTP_MFA_ENROLLMENT_ENABLED=true
AUTH_TOTP_MFA_STEP_UP_ENABLED=true

########################################
# MySQL
########################################
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=apppass

########################################
# Kafka topics
########################################
# event-indexer
EVENT_INDEX_TOPIC=event-index-events
EVENT_INDEX_GROUP_ID=event-indexer
EVENT_INDEX_DLQ_TOPIC=event-index-events-dlq
# club-indexer
CLUB_INDEX_TOPIC=club-index-events
CLUB_INDEX_GROUP_ID=club-indexer
CLUB_INDEX_DLQ_TOPIC=club-index-events-dlq
# clubpost-indexer
CLUB_POST_INDEX_TOPIC=clubpost-index-events
CLUB_POST_INDEX_GROUP_ID=clubpost-indexer
CLUB_POST_INDEX_DLQ_TOPIC=clubpost-index-events-dlq
# email-worker (EMAIL_TOPIC also published by the main server)
EMAIL_TOPIC=eventxperience-email
EMAIL_GROUP_ID=email-worker
EMAIL_DLQ_TOPIC=eventxperience-email-dlq
EMAIL_STATUS_TOPIC=eventxperience-email-status
# sms-worker (SMS_TOPIC also published by the main server)
SMS_TOPIC=eventxperience-sms
SMS_GROUP_ID=sms-worker
SMS_DLQ_TOPIC=eventxperience-sms-dlq

########################################
# Email / SMTP (email-worker)
########################################
SMTP_SERVER=
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

########################################
# SMS / Twilio (sms-worker)
########################################
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_PHONE_NUMBER=

########################################
# OAuth / captcha
########################################
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Consumed by the frontend as MSAL_CLIENT_ID and by the backend as MS_CLIENT_ID
# (mapped in docker-compose.yml). Set once here.
MSAL_CLIENT_ID=
MS_TENANT_ID=
APPLE_CLIENT_ID=
GOOGLE_SITE_KEY=
GOOGLE_CAPTCHA_SECRET=
CAPTCHA_PROVIDER=google

########################################
# Storage (Azure)
########################################
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=

########################################
# Payments (Stripe)
########################################
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3090/payment/success
STRIPE_CANCEL_URL=http://localhost:3090/payment/cancel

########################################
# Seeders (optional)
########################################
RUN_SEEDERS=false
# Dev/test only: when true, seeded accounts (emails under @seed.eventxperience.test)
# skip the captcha and MFA step-up checks. Ignored in production and defaults to false.
AUTH_SEED_ACCOUNT_BYPASS=false
AUTH_SEED_USERS_PASSWORD=Password123!
AUTH_SEED_ADMIN_PASSWORD=AdminPassword123!
AUTH_SEED_ADMIN_EMAIL=admin@seed.eventxperience.test
AUTH_SEED_ADMIN_USERNAME=seedadmin
AUTH_SEED_ADMIN_NAME=Seed Admin
