########################################
# Environment
########################################
ASPNETCORE_ENVIRONMENT=Development
APP_ENV=development
NODE_ENV=development

########################################
# URLs
########################################
BACKEND_URL=http://localhost:8090/api
FRONTEND_URL=http://localhost:3090

########################################
# Backend
########################################
BACKEND_PORT=8090
DB_CONNECTION_STRING=Server=mysql;Port=3306;Database=appdb;User=appuser;Password=apppass
REDIS_URL=redis:6379
ELASTICSEARCH_URL=http://elasticsearch:9200
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

########################################
# JWT
########################################
JWT_SECRET_ACCESS=change_me_access_secret_12345678901234567890
JWT_SECRET_VERIFICATION=change_me_verification_secret_12345678901234567890

########################################
# MySQL
########################################
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=apppass

########################################
# Kafka topics (event-indexer)
########################################
EVENT_INDEX_TOPIC=event-index-events
EVENT_INDEX_GROUP_ID=event-indexer
EVENT_INDEX_DLQ_TOPIC=event-index-events-dlq

########################################
# Email / SMTP (email-worker)
########################################
SMTP_SERVER=
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

########################################
# OAuth / reCAPTCHA
########################################
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MSAL_CLIENT_ID=
MS_TENANT_ID=
APPLE_CLIENT_ID=
GOOGLE_SITE_KEY=
GOOGLE_CAPTCHA_SECRET=

########################################
# Azure Storage
########################################
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=

########################################
# PayPal
########################################
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET_KEY=

########################################
# Seeders (optional)
########################################
RUN_SEEDERS=false
AUTH_SEED_USERS_PASSWORD=Password123!
AUTH_SEED_ADMIN_PASSWORD=AdminPassword123!
AUTH_SEED_ADMIN_EMAIL=admin@seed.eventxperience.test
AUTH_SEED_ADMIN_USERNAME=seedadmin
AUTH_SEED_ADMIN_NAME=Seed Admin
